# ============================================================
# AISaraj Frontend — Environment Variables
# ============================================================
# Create a .env file in the aisaraj-frontend/ root with these values.
# React requires all custom env vars to start with REACT_APP_
# ============================================================

# ──────────────────── BACKEND API ────────────────────
# URL of the Django REST API (no trailing slash)
REACT_APP_API_URL=http://localhost:8000/api/v1

# ──────────────────── GETSTREAM VIDEO ────────────────────
# Same API key as backend (public key, safe for frontend)
# Get from https://getstream.io/video/ → Dashboard → App
REACT_APP_GETSTREAM_API_KEY=khpzaxwdcj56
