# ============================================================
# AISaraj Backend — Environment Variables
# ============================================================
# Copy this file to .env before running the project:
#   cp .env.example .env
# Then fill in the values below.
# ============================================================

# ──────────────────── DJANGO CORE ────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated. In production: your domain name
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────────── DATABASE ────────────────────
# For PostgreSQL (local dev):
#   DB_ENGINE=django.db.backends.postgresql
# For MySQL (PythonAnywhere):
#   DB_ENGINE=django.db.backends.mysql
DB_ENGINE=django.db.backends.postgresql
DB_NAME=aisaraj
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ──────────────────── JWT AUTHENTICATION ────────────────────
# Access token lifetime in minutes (default: 30)
JWT_ACCESS_LIFETIME_MINUTES=30

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_LIFETIME_DAYS=7

# ──────────────────── GETSTREAM VIDEO ────────────────────
# Sign up at https://getstream.io/video/
# Dashboard → App → API Key & Secret
GETSTREAM_API_KEY=your-getstream-api-key
GETSTREAM_API_SECRET=your-getstream-api-secret

# Which video provider to use (currently only "getstream")
VIDEO_PROVIDER=getstream

# ──────────────────── GEMINI AI (Google) ────────────────────
# Sign up at https://aistudio.google.com/app/apikey
# Create an API key for Gemini API
GEMINI_API_KEY=your-gemini-api-key

# ──────────────────── FILE STORAGE ────────────────────
# "local" = Django media folder (development)
# "s3" = AWS S3 bucket (production)
FILE_STORAGE=local

# Required only when FILE_STORAGE=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=aisaraj-media
AWS_S3_REGION_NAME=us-east-1

# ──────────────────── CORS ────────────────────
# Frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:3000
